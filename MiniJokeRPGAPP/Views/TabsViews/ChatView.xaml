<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniJokeRPGAPP.Views.TabsViews.ChatView"
             BackgroundColor="#121212">
    <Grid RowDefinitions="Auto, *, Auto">

        <Border Grid.Row="0" 
                BackgroundColor="#1E1E24" 
                StrokeThickness="0"
                Padding="16,12"
                Margin="0,0,0,5">
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="⚔️" FontSize="16" VerticalOptions="Center"/>
                <Label Text="{Binding NombreAmigo}" 
                       FontAttributes="Bold" 
                       TextColor="#E0E0E0" 
                       FontSize="16"
                       CharacterSpacing="0.5"
                       VerticalOptions="Center"></Label>
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" 
                        VerticalScrollBarVisibility="Never"
                        ItemsSource="{Binding Mensajes}"
                        Margin="10,5"
                        ItemsUpdatingScrollMode="KeepLastItemInView">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="2,0">

                        <Border IsVisible="{Binding NoEsEmisor}" 
                                BackgroundColor="#1E1E24"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12,12,12,2"
                                HorizontalOptions="Start"  
                                MaximumWidthRequest="260"
                                Padding="12,8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Contenido}" 
                                       TextColor="#E0E0E0"
                                       FontSize="14"
                                       IsVisible="{Binding EsTexto}"/>

                                <Border IsVisible="{Binding EsImagen}"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        HorizontalOptions="Center">
                                    <Image Source="{Binding Archivo}"
                                           HeightRequest="220"
                                           Aspect="AspectFill" />
                                </Border>

                                <Label Text="{Binding FechaEnvio, StringFormat='{0:t}'}" 
                                       TextColor="#777777"
                                       FontSize="10"
                                       HorizontalOptions="End"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border IsVisible="{Binding EsEmisor}" 
                                BackgroundColor="Indigo"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12,12,2,12"
                                HorizontalOptions="End" 
                                MaximumWidthRequest="260"
                                Padding="12,8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Contenido}" 
                                       TextColor="White"
                                       FontSize="14"
                                       IsVisible="{Binding EsTexto}"/>

                                <Border IsVisible="{Binding EsImagen}"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        HorizontalOptions="Center">
                                    <Image Source="{Binding Archivo}"
                                           HeightRequest="220"
                                           Aspect="AspectFill" />
                                </Border>

                                <Label Text="{Binding FechaEnvio, StringFormat='{0:t}'}" 
                                       TextColor="#B39DDB"
                                       FontSize="10"
                                       HorizontalOptions="End"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2" 
              ColumnDefinitions="Auto, *, Auto" 
              Padding="12,10" 
              BackgroundColor="#121212">

            <Button Grid.Column="0" 
                    Text="📷"
                    FontSize="16"
                    TextColor="White"
                    BackgroundColor="#2B2B36"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    Padding="0"
                    Margin="0,0,8,0"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.SeleccionarImagenCommand}" />

            <Border Grid.Column="1" 
                    BackgroundColor="#1E1E24"
                    StrokeThickness="1"
                    Stroke="#2B2B36"
                    StrokeShape="RoundRectangle 20"
                    HeightRequest="40"
                    Padding="15,0"
                    Margin="0,0,8,0">
                <Entry Placeholder="Escribe un mensaje..." 
                       PlaceholderColor="#555555"
                       Text="{Binding Mensaje}" 
                       TextColor="White" 
                       FontSize="14"
                       VerticalOptions="Center"
                       BackgroundColor="Transparent"/>
            </Border>

            <Button Grid.Column="2" 
                    Text="➔"
                    FontSize="16"
                    TextColor="White"
                    BackgroundColor="DarkRed"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    Padding="0"
                    Command="{Binding MandarMensajeCommand}"/>

        </Grid>
    </Grid>
</ContentView>