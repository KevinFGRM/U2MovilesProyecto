<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniJokeRPGAPP.Views.TabsViews.PresentacionView"
             BackgroundColor="#121212">

    <Grid VerticalOptions="Center" 
          HorizontalOptions="Center" 
          Padding="30">

        <VerticalStackLayout Spacing="12" HorizontalOptions="Center">

            <Border BackgroundColor="#1E1E24"
                    StrokeShape="RoundRectangle 24"
                    HeightRequest="80"
                    WidthRequest="80"
                    HorizontalOptions="Center"
                    Margin="0,0,0,10"
                    StrokeThickness="1"
                    Stroke="Indigo">

                <Label Text="⚔️" 
                       FontSize="32" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"/>
            </Border>

            <Label Text="¡SESIÓN INICIADA!" 
                   TextColor="DarkRed" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="1"/>

            <Label Text="Navega con los controles de abajo para iniciar tu aventura." 
                   TextColor="#888888" 
                   FontSize="14" 
                   HorizontalTextAlignment="Center"
                   LineHeight="1.2"
                   Margin="10,0"/>

        </VerticalStackLayout>

    </Grid>
</ContentView>