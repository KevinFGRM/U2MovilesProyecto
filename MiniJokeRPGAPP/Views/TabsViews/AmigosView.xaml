<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniJokeRPGAPP.Views.TabsViews.AmigosView"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <Grid Grid.Row="0"  ColumnDefinitions="*,*,*" ColumnSpacing="10"
                               Margin="10,15">

            <Button Text="AMIGOS"  Grid.Column="0"
                    Command="{Binding CargarAmigosCommand}"
                    BackgroundColor="#1E1E24"
                    TextColor="#E0E0E0"
                    FontSize="12"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Padding="15,0"
                    CornerRadius="6">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding PestañaSeleccionada}" Value="Amigos">
                        <Setter Property="BackgroundColor" Value="Green"/>
                        <Setter Property="TextColor" Value="White"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            
            <Button Text="TODOS" Grid.Column="1" 
                    Command="{Binding CargarUsuariosCommand}"
                    BackgroundColor="#1E1E24"
                    TextColor="#E0E0E0"
                    FontSize="12"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Padding="15,0"
                    CornerRadius="6">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding PestañaSeleccionada}" Value="Todos">
                        <Setter Property="BackgroundColor" Value="DarkRed"/>
                        <Setter Property="TextColor" Value="White"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <Button Text="PENDIENTES" Grid.Column="2"
                    Command="{Binding CargarPendientesCommand}"
                    BackgroundColor="#1E1E24"
                    TextColor="#E0E0E0"
                    FontSize="12"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Padding="15,0"
                    CornerRadius="6">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding PestañaSeleccionada}" Value="Pendientes">
                        <Setter Property="BackgroundColor" Value="Indigo"/>
                        <Setter Property="TextColor" Value="White"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <Label Grid.Row="1" 
               Text="{Binding MensajeError}" 
               TextColor="Tomato" 
               FontSize="13"
               FontAttributes="Italic"
               HorizontalOptions="Center" 
               Margin="10"/>

        <ActivityIndicator Grid.Row="2" 
                           IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}"
                           Color="Indigo"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>

        <CollectionView Grid.Row="3" 
                        ItemsSource="{Binding Usuarios}"
                        Margin="10,0">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#1E1E24"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Margin="5,2">

                        <Grid Padding="16" ColumnDefinitions="*, Auto">

                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4">
                                <Label Text="{Binding NombreUsuario}" 
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="#E0E0E0"/>

                                <HorizontalStackLayout IsVisible="{Binding SoyEmisor}">
                                    <Label Text="Solicitud enviada (pendiente)" 
                                           FontSize="12" 
                                           TextColor="#888888"
                                           FontAttributes="Italic"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <StackLayout Grid.Column="1" VerticalOptions="Center">

                                <Button Text="AGREGAR" 
                                        IsVisible="{Binding EsNinguno}" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.AgregarAmigoCommand}" 
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="DarkRed"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FontSize="12"
                                        HeightRequest="36"
                                        Padding="15,0"
                                        CornerRadius="6"/>

                                <HorizontalStackLayout Spacing="0" IsVisible="False">
                                    <HorizontalStackLayout.Triggers>
                                        <MultiTrigger TargetType="HorizontalStackLayout">
                                            <MultiTrigger.Conditions>
                                                <BindingCondition Binding="{Binding EsPendiente}" Value="True"/>
                                                <BindingCondition Binding="{Binding SoyEmisor}" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter Property="IsVisible" Value="True"/>
                                        </MultiTrigger>
                                    </HorizontalStackLayout.Triggers>

                                    <Button Text="ACEPTAR" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.AceptarAmigoCommand}" 
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Indigo"
                                            TextColor="White"
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            HeightRequest="36"
                                            Padding="15,0"
                                            CornerRadius="6"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="8" IsVisible="{Binding EsAmigo}">
                                    <Button Text="CHAT" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.AbrirChatCommand}" 
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#2B2B36"
                                            TextColor="#E0E0E0"
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            HeightRequest="36"
                                            Padding="12,0"
                                            CornerRadius="6"/>

                                    <Button Text="RETAR" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.CrearPartidaCommand}" 
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="DarkRed"
                                            TextColor="White"
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            HeightRequest="36"
                                            Padding="12,0"
                                            CornerRadius="6"/>
                                </HorizontalStackLayout>

                            </StackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>