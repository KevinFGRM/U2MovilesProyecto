<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniJokeRPGAPP.Views.TabsJuego.PersonajesView">
    <Grid BackgroundColor="#1E1E1E">

        <CollectionView
            ItemsSource="{Binding Personajes}"
            Margin="10">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout
            Orientation="Vertical"
            ItemSpacing="15"/>
            </CollectionView.ItemsLayout>
            <CollectionView.Header>

                <Border
                    Padding="15"
                    Margin="0,0,0,10"
                    BackgroundColor="#2B2B2B"
                    StrokeShape="RoundRectangle 20">

                    <VerticalStackLayout>

                        <Label
                            Text="Selecciona tu personaje"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="White"/>

                        <Label
                            Text="{Binding EstadoPartida}"
                            FontSize="14"
                            TextColor="#BDBDBD"/>

                    </VerticalStackLayout>

                </Border>

            </CollectionView.Header>

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Border
                        Margin="0,0,0,15"
                        Padding="15"
                        BackgroundColor="#2B2B2B"
                        StrokeShape="RoundRectangle 25">

                        <VerticalStackLayout Spacing="15">

                            <!-- NOMBRE -->
                            <Label
                                Text="{Binding Nombre}"
                                FontSize="28"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                TextColor="White"/>

                            <!-- STATS -->
                            <Grid
                                ColumnDefinitions="*,*"
                                RowDefinitions="Auto,Auto"
                                ColumnSpacing="15"
                                RowSpacing="15">

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Padding="10"
                                    BackgroundColor="#3A3A3A"
                                    StrokeShape="RoundRectangle 15">

                                    <VerticalStackLayout>

                                        <Label
                                            Text="❤️ Vida"
                                            TextColor="#FF8A80"/>

                                        <Label
                                            Text="{Binding VidaBase}"
                                            FontSize="20"
                                            TextColor="White"/>

                                    </VerticalStackLayout>

                                </Border>

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Padding="10"
                                    BackgroundColor="#3A3A3A"
                                    StrokeShape="RoundRectangle 15">

                                    <VerticalStackLayout>

                                        <Label
                                            Text="🔵 Mana"
                                            TextColor="#82B1FF"/>

                                        <Label
                                            Text="{Binding ManaBase}"
                                            FontSize="20"
                                            TextColor="White"/>

                                    </VerticalStackLayout>

                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Padding="10"
                                    BackgroundColor="#3A3A3A"
                                    StrokeShape="RoundRectangle 15">

                                    <VerticalStackLayout>

                                        <Label
                                            Text="⚔ Ataque"
                                            TextColor="#FFD180"/>

                                        <Label
                                            Text="{Binding AtaqueBase}"
                                            FontSize="20"
                                            TextColor="White"/>

                                    </VerticalStackLayout>

                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Padding="10"
                                    BackgroundColor="#3A3A3A"
                                    StrokeShape="RoundRectangle 15">

                                    <VerticalStackLayout>

                                        <Label
                                            Text="🛡 Defensa"
                                            TextColor="#A5D6A7"/>

                                        <Label
                                            Text="{Binding DefensaBase}"
                                            FontSize="20"
                                            TextColor="White"/>

                                    </VerticalStackLayout>

                                </Border>

                            </Grid>

                            <!-- HABILIDADES -->
                            <VerticalStackLayout
                                BindableLayout.ItemsSource="{Binding Habilidades}">

                                <BindableLayout.ItemTemplate>

                                    <DataTemplate>

                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="12"
                                            BackgroundColor="#3A3A3A"
                                            StrokeShape="RoundRectangle 18">

                                            <VerticalStackLayout>

                                                <Label
                                                    Text="{Binding Nombre}"
                                                    FontSize="20"
                                                    FontAttributes="Bold"
                                                    TextColor="White"/>

                                                <Label
                                                    Text="{Binding Descripcion}"
                                                    FontSize="14"
                                                    TextColor="#D0D0D0"/>

                                                <Grid
                                                    Margin="0,10,0,0"
                                                    ColumnDefinitions="*,*,*">

                                                    <Label
                                                        Text="{Binding CostoMana, StringFormat='Mana: {0}'}"
                                                        TextColor="#82B1FF"/>

                                                    <Label
                                                        Grid.Column="1"
                                                        Text="{Binding Dano, StringFormat='Daño: {0}'}"
                                                        TextColor="#FF8A80"/>

                                                    <Label
                                                        Grid.Column="2"
                                                        Text="{Binding Curacion, StringFormat='Curación: {0}'}"
                                                        TextColor="#A5D6A7"/>

                                                </Grid>

                                            </VerticalStackLayout>

                                        </Border>

                                    </DataTemplate>

                                </BindableLayout.ItemTemplate>

                            </VerticalStackLayout>

                            <!-- BOTON -->
                            <Button
                                Text="Seleccionar personaje"
                                FontSize="18"
                                HeightRequest="55"
                                Command="{Binding
                                Source={RelativeSource AncestorType={x:Type ContentView}},
                                Path=BindingContext.SeleccionarPersonajeCommand}"
                                CommandParameter="{Binding .}"/>

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentView>
