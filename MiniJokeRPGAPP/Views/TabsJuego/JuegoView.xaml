<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniJokeRPGAPP.Views.TabsJuego.JuegoView"
             BackgroundColor="#121212" x:Name="juegoView">
    <Grid RowDefinitions="Auto, *, Auto" Padding="12" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,4">

                <Label Grid.Column="1" 
               Text="ARENA DE COMBATE" 
               HorizontalOptions="Center" 
               VerticalOptions="Center"
               TextColor="DarkRed" 
               FontAttributes="Bold" 
               FontSize="12" 
               CharacterSpacing="2"/>

                <Button Grid.Column="2"
                Text="🔄"
                FontAttributes="Bold"
                FontSize="14"
                WidthRequest="36"
                HeightRequest="36"
                CornerRadius="18"
                Padding="0"
                BackgroundColor="#1E1E24"
                TextColor="Tomato"
                BorderWidth="1"
                BorderColor="DarkRed"
                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.CargarEstadoCommand}">
                    <Button.Triggers>
                        <Trigger TargetType="Button" Property="IsEnabled" Value="False">
                            <Setter Property="BackgroundColor" Value="#15151A" />
                            <Setter Property="TextColor" Value="#555555" />
                        </Trigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="8">

                <Border Grid.Column="0" BackgroundColor="#1E1E24" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12,10">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding EstadoPartida.Jugador1}" FontAttributes="Bold" TextColor="#E0E0E0" FontSize="14" HorizontalOptions="Center"/>

                        <VerticalStackLayout Spacing="2">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="❤️ HP" FontSize="10" TextColor="#888888" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text="{Binding EstadoPartida.VidaJugador1}" FontSize="11" TextColor="White" FontAttributes="Bold"/>
                            </Grid>
                            <ProgressBar Progress="{Binding EstadoPartida.VidaJugador1}" ProgressColor="Tomato" BackgroundColor="#15151A"/>
                        </VerticalStackLayout>

                        <Label Text="{Binding EstadoPartida.ManaJugador1, StringFormat='🔮 {0} PM'}" FontSize="12" TextColor="#90CAF9" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Label Grid.Column="1" Text="VS" 
                       TextColor="DarkRed" 
                       FontAttributes="Bold" 
                       FontSize="16" 
                       VerticalOptions="Center" 
                       HorizontalOptions="Center" 
                       Margin="4,0"/>

                <Border Grid.Column="2" BackgroundColor="#1E1E24" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12,10">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding EstadoPartida.Jugador2}" FontAttributes="Bold" TextColor="#E0E0E0" FontSize="14" HorizontalOptions="Center"/>

                        <VerticalStackLayout Spacing="2">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="❤️ HP" FontSize="10" TextColor="#888888" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text="{Binding EstadoPartida.VidaEnemigo2}" FontSize="11" TextColor="White" FontAttributes="Bold"/>
                            </Grid>
                            <ProgressBar Progress="{Binding EstadoPartida.VidaEnemigo2}" ProgressColor="Tomato" BackgroundColor="#15151A"/>
                        </VerticalStackLayout>

                        <Label Text="{Binding EstadoPartida.ManaEnemigo2, StringFormat='🔮 {0} PM'}" FontSize="12" TextColor="#90CAF9" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" HorizontalOptions="Fill">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding EstadoPartida.MiTurno}" Value="True">
                        <Setter Property="BackgroundColor" Value="#1B2D24" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding EstadoPartida.MiTurno}" Value="False">
                        <Setter Property="BackgroundColor" Value="#1E1E24" />
                    </DataTrigger>
                </Border.Triggers>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="{Binding EstadoPartida.Estado}" TextColor="#BBBBBB" FontSize="12" VerticalOptions="Center" FontAttributes="Italic"/>

                    <Label Grid.Column="1" FontSize="13" FontAttributes="Bold" VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding EstadoPartida.MiTurno}" Value="True">
                                <Setter Property="Text" Value="⚔️ ¡TU TURNO!" />
                                <Setter Property="TextColor" Value="LightGreen" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding EstadoPartida.MiTurno}" Value="False">
                                <Setter Property="Text" Value="⏳ ESPERANDO RIVAL" />
                                <Setter Property="TextColor" Value="#888888" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <Border Grid.Row="1" BackgroundColor="#15151A" StrokeThickness="1" Stroke="#2B2B36" StrokeShape="RoundRectangle 12" Padding="12">
            <Grid RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="BITÁCORA DE COMBATE" FontSize="11" FontAttributes="Bold" TextColor="#666666" CharacterSpacing="1" Margin="0,0,0,8"/>

                <CollectionView Grid.Row="1" ItemsSource="{Binding Acciones}" VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="{Binding Descripcion}" TextColor="#D0D0D0" FontSize="13" LineBreakMode="WordWrap"/>
                                <Label Grid.Column="1" Text="{Binding Fecha, StringFormat='{0:HH:mm:ss}'}" TextColor="#555555" FontSize="11" VerticalOptions="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <Border Grid.Row="2" BackgroundColor="#1E1E24" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="16,12" Margin="0,4,0,0">
            <VerticalStackLayout Spacing="10">

                <Grid ColumnDefinitions="*, Auto">

                    <Button Grid.Column="1" 
                            Text="DESCANSAR" 
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.DescansarCommand}"
                            IsEnabled="{Binding EstadoPartida.MiTurno}"
                            BackgroundColor="Indigo"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="10"
                            HeightRequest="30"
                            Padding="12,0"
                            CornerRadius="4">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding EstadoPartida.NoEsMiTurno}" Value="True">
                                <Setter Property="BackgroundColor" Value="#2B2B36" />
                                <Setter Property="TextColor" Value="#555555" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <BoxView HeightRequest="1" Color="#2B2B36" Margin="0,2"/>

                <Label Text="TUS HABILIDADES" FontSize="11" FontAttributes="Bold" TextColor="#888888" CharacterSpacing="1"/>

                <CollectionView ItemsSource="{Binding EstadoPartida.HabilidadesJugador1}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout>
                                <Button Text="{Binding Nombre}" 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.UsarHabilidadCommand}" 
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.EstadoPartida.MiTurno}"
                                    BackgroundColor="DarkRed"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    HeightRequest="42"
                                    Padding="4,0"
                                    CornerRadius="6">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.EstadoPartida.MiTurno}" Value="False">
                                            <Setter Property="BackgroundColor" Value="#2B2B36" />
                                            <Setter Property="TextColor" Value="#555555" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.RowSpan="3" 
              BackgroundColor="#F2121212" 
              IsVisible="False" 
              Padding="30">
            <Grid.Triggers>
                <DataTrigger TargetType="Grid" Binding="{Binding Plantilla}" Value="True">
                    <Setter Property="IsVisible" Value="True"></Setter>
                </DataTrigger>
                <DataTrigger TargetType="Grid" Binding="{Binding EstadoPartida.Estado}" Value="finalizada">
                    <Setter Property="IsVisible" Value="True"></Setter>
                </DataTrigger>
            </Grid.Triggers>
            <Border BackgroundColor="#1E1E24"
                    StrokeThickness="1"
                    Stroke="DarkRed"
                    StrokeShape="RoundRectangle 16"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="300"
                    Padding="24">

                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">

                    <Label Text="🏆" FontSize="44" HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding Plantilla}" Value="True">
                                <Setter Property="Text" Value="⏳"></Setter>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <Label Text="¡PARTIDA FINALIZADA!" 
                           TextColor="DarkRed" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           CharacterSpacing="1"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding Plantilla}" Value="True">
                                <Setter Property="Text" Value="Esperando que el openente elija..."></Setter>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <Label Text="{Binding GanadorTexto}" 
                           TextColor="White" 
                           FontSize="15" 
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>

                    <Button Text="VOLVER AL MENÚ" 
                            Command="{Binding CerrarPartidaCommand}"
                            BackgroundColor="Indigo"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="12"
                            HeightRequest="44"
                            WidthRequest="200"
                            CornerRadius="8"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentView>