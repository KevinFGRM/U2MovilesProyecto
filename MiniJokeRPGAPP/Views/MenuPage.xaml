<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniJokeRPGAPP.Views.MenuPage"
             xmlns:views="clr-namespace:MiniJokeRPGAPP.Views.TabsViews"
             xmlns:juego="clr-namespace:MiniJokeRPGAPP.Views.TabsJuego"
             xmlns:viewmodels="clr-namespace:MiniJokeRPGAPP.ViewModels"
             Title="Mini Joke RPG"
             x:DataType="viewmodels:MenuViewModel"
             BackgroundColor="#121212">
    <Grid RowDefinitions="*,80">
    
        <Grid>
            <views:PresentacionView IsVisible="False">
                <views:PresentacionView.Triggers>
                    <DataTrigger TargetType="views:PresentacionView" Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VistaActual}" Value="Presentacion">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </views:PresentacionView.Triggers>
            </views:PresentacionView>
            <views:PartidasView BindingContext="{Binding PartidasVM}" IsVisible="False">
                <views:PartidasView.Triggers>
                    <DataTrigger TargetType="views:PartidasView" Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VistaActual}" Value="Partidas">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </views:PartidasView.Triggers>
            </views:PartidasView>
            <views:AmigosView BindingContext="{Binding AmigosVM}" IsVisible="False">
                <views:AmigosView.Triggers>
                    <DataTrigger TargetType="views:AmigosView" Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VistaActual}" Value="Amigos">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </views:AmigosView.Triggers>
            </views:AmigosView>

            <views:PerfilView BindingContext="{Binding AuthVM}" IsVisible="False">
                <views:PerfilView.Triggers>
                    <DataTrigger TargetType="views:PerfilView" Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VistaActual}" Value="Perfil">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </views:PerfilView.Triggers>
            </views:PerfilView>

            <views:ChatView BindingContext="{Binding MensajesVM}" IsVisible="False">
                <views:ChatView.Triggers>
                    <DataTrigger TargetType="views:ChatView" Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VistaActual}" Value="Chat">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </views:ChatView.Triggers>
            </views:ChatView>
            <juego:PersonajesView BindingContext="{Binding PartidasVM}" IsVisible="False">
                <juego:PersonajesView.Triggers>
                    <DataTrigger TargetType="juego:PersonajesView" Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VistaActual}" Value="Personajes">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </juego:PersonajesView.Triggers>
            </juego:PersonajesView>
            <juego:JuegoView BindingContext="{Binding PartidasVM}" IsVisible="False">
                <juego:JuegoView.Triggers>
                    <DataTrigger TargetType="juego:JuegoView" Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VistaActual}" Value="Juego">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </juego:JuegoView.Triggers>
            </juego:JuegoView>
        </Grid>

        <!-- BARRA DE NAVEGACIÓN INFERIOR (Estilo TabBar de Videojuego) -->
        <Border Grid.Row="1" 
                BackgroundColor="#1E1E24" 
                StrokeThickness="1" 
                Stroke="#2B2B36"
                StrokeShape="RoundRectangle 16,16,0,0">
            <!-- Esquinas superiores redondeadas -->

            <Grid ColumnDefinitions="*,*,*">

                <!-- PESTAÑA: PARTIDAS -->
                <Grid Grid.Column="0">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="2" InputTransparent="True">
                        <Label Text="⚔️" FontSize="18" HorizontalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding VistaActual}" Value="Partidas">
                                    <Setter Property="TextColor" Value="DarkRed" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Text="Partidas" FontSize="11" FontAttributes="Bold" TextColor="#888888" HorizontalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding VistaActual}" Value="Partidas">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>
                    <!-- El botón invisible cubre todo el cuadrante para facilitar el toque -->
                    <Button BackgroundColor="Transparent" CornerRadius="0" Command="{Binding CambiarVistaCommand}" CommandParameter="Partidas" />
                </Grid>

                <!-- PESTAÑA: AMIGOS -->
                <Grid Grid.Column="1">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="2" InputTransparent="True">
                        <Label Text="👥" FontSize="18" HorizontalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding VistaActual}" Value="Amigos">
                                    <Setter Property="TextColor" Value="Indigo" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Text="Amigos" FontSize="11" FontAttributes="Bold" TextColor="#888888" HorizontalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding VistaActual}" Value="Amigos">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>
                    <Button BackgroundColor="Transparent" CornerRadius="0" Command="{Binding CambiarVistaCommand}" CommandParameter="Amigos" />
                </Grid>

                <!-- PESTAÑA: PERFIL -->
                <Grid Grid.Column="2">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="2" InputTransparent="True">
                        <Label Text="👤" FontSize="18" HorizontalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding VistaActual}" Value="Perfil">
                                    <Setter Property="TextColor" Value="Indigo" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Text="Perfil" FontSize="11" FontAttributes="Bold" TextColor="#888888" HorizontalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding VistaActual}" Value="Perfil">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>
                    <Button BackgroundColor="Transparent" CornerRadius="0" Command="{Binding CambiarVistaCommand}" CommandParameter="Perfil" />
                </Grid>

            </Grid>
        </Border>

    </Grid>
</ContentPage>