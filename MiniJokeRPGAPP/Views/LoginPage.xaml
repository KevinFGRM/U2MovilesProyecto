<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniJokeRPGAPP.Views.LoginPage"
             Title="Mini Joke RPG">
    <Grid >
        <VerticalStackLayout VerticalOptions="Center">
            <Label Text="Iniciar Sesion" FontSize="28" HorizontalOptions="Center" Margin="0,-50,0,50" ></Label>

            <Entry Placeholder="Correo" Text="{Binding Correo}"></Entry>

            <Entry Placeholder="Contraseña" IsPassword="True" Text="{Binding Contrasena}"></Entry>
            
            <Grid ColumnDefinitions="*, auto" Margin="10, 10, 10, 0" >
                
                <Label FontFamily="Verdana" TextColor="Black" Text="¿No tienes cuenta?" VerticalOptions="Center"></Label>
                <Button Grid.Column="1" TextColor="Black" BackgroundColor="Transparent" Text="Registrarse" Command="{Binding IrRegistrarCommand}"></Button>

            </Grid>
            
            <Label Margin="10, 10, 10, 0" FontFamily="Verdana" TextColor="Red" Text="{Binding MensajeError}"></Label>

            <Button Margin="10, 10, 10, 0" Text="Iniciar Sesión" Command="{Binding LoginCommand}"></Button>

        </VerticalStackLayout>

        <Grid BackgroundColor="#80000000" IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" />
                <Label Text="Cargando..." TextColor="White" FontFamily="Verdana" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>